{
  "scripts": {
    "gen-stats": "node -e \"const p=require('os').platform();const e=p==='linux'?'linux':p==='darwin'?'darwin':'darwin';require('child_process').execSync('./.vitepress/stats_gen/whxnotes_stats_gen_'+e,{stdio:'inherit'})\"",
    "docs:dev": "vitepress dev .",
    "docs:build": "npm run gen-stats && vitepress build .",
    "docs:preview": "vitepress preview ."
  },
  "dependencies": {
    "markdown-it-cjk-friendly": "^2.0.2",
    "markdown-it-footnote": "^4.0.0",
    "medium-zoom": "^1.1.0",
    "vitepress": "^1.6.4"
  },
  "devDependencies": {
    "markdown-it-mathjax3": "^4.3.2",
    "mermaid": "^11.15.0",
    "vitepress-sidebar": "^1.33.1"
  }
}
